# ──────────────────────────────────────────────────────────────────────────────
# a2a-brainstorm — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/a2a_brainstorm?sslmode=disable
POSTGRES_PASSWORD=postgres
# Host port mapping for docker compose (change these to avoid collisions)
POSTGRES_HOST_PORT=5432
BACKEND_HOST_PORT=8080
AGENT_HOST_PORT=9090

# ── Global LLM (used when no agent-level or session-level override is set) ────
# provider: "copilot" | "claude"
GLOBAL_LLM_PROVIDER=copilot
GLOBAL_LLM_MODEL=gpt-4o
# The name of the env var that holds the actual API key (CredentialRef pattern)
GLOBAL_LLM_CREDENTIAL_REF=COPILOT_API_KEY

# ── LLM API keys (referenced by GLOBAL_LLM_CREDENTIAL_REF or agent llm_config) ─
# ⚠  Never store real keys in this file — keys belong in .env only
COPILOT_API_KEY=
CLAUDE_API_KEY=

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=8080

# ── Agent ────────────────────────────────────────────────────────────────────
AGENT_PORT=9090
# Comma-separated list of agent base URLs (for local dev single instance)
AGENT_ENDPOINTS=http://localhost:9090
# Agent-level LLM config (overrides global for this binary)
AGENT_LLM_PROVIDER=copilot
AGENT_LLM_MODEL=gpt-4o
AGENT_LLM_CREDENTIAL_REF=COPILOT_API_KEY

# ── Iteration engine ─────────────────────────────────────────────────────────
MAX_ITERATIONS=10
CONVERGENCE_THRESHOLD=0.02
