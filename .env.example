# ──────────────────────────────────────────────────────────────────────────────
# a2a-brainstorm — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/a2a_brainstorm?sslmode=disable
POSTGRES_PASSWORD=postgres
# Host port mapping for docker compose (change these to avoid collisions)
POSTGRES_HOST_PORT=5432
BACKEND_HOST_PORT=8080
AGENT_HOST_PORT=9090

# ── Global LLM (used when no agent-level or session-level override is set) ────
# provider: "copilot" | "claude"
GLOBAL_LLM_PROVIDER=copilot
GLOBAL_LLM_MODEL=gpt-4o
# The name of the env var that holds the actual API key (CredentialRef pattern)
GLOBAL_LLM_CREDENTIAL_REF=COPILOT_API_KEY

# ── LLM API keys (referenced by GLOBAL_LLM_CREDENTIAL_REF or agent llm_config) ─
# ⚠  Never store real keys in this file — keys belong in .env only
COPILOT_API_KEY=
CLAUDE_API_KEY=

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=8080

# ── Agent ────────────────────────────────────────────────────────────────────
AGENT_PORT=9090
# Comma-separated list of agent base URLs (for local dev single instance)
AGENT_ENDPOINTS=http://localhost:9090
# Agent-level LLM config (overrides global for this binary)
AGENT_LLM_PROVIDER=copilot
AGENT_LLM_MODEL=gpt-4o
AGENT_LLM_CREDENTIAL_REF=COPILOT_API_KEY

# ── Iteration engine ─────────────────────────────────────────────────────────
MAX_ITERATIONS=10
CONVERGENCE_THRESHOLD=0.02

# ── OpenCode Server (only required when AGENT_LLM_PROVIDER=opencode) ─────────
# Switch the agent binary to route all LLM calls through a running OpenCode
# server instance rather than calling the Copilot API directly.
# The OpenCode server must be started and authenticated before the agent starts.
# See docs/STARTUP_GUIDE.md — "Running with OpenCode Server" for the full setup.
#
# Uncomment the line below to activate the OpenCode provider for the agent:
# AGENT_LLM_PROVIDER=opencode

# URL where the OpenCode server listens.
# Use the Docker service name when running inside Docker Compose:
AGENT_OPENCODE_BASE_URL=http://opencode:4096

# Model in "providerID/modelID" format understood by OpenCode.
# Examples:  github/gpt-4o  |  anthropic/claude-sonnet-4-5  |  openai/gpt-4o
AGENT_OPENCODE_MODEL=github/gpt-4o

# Env var NAME that holds the OpenCode server HTTP Basic Auth username.
# The _REF pattern keeps credentials out of .env.example and in .env only.
AGENT_OPENCODE_USERNAME_REF=OPENCODE_SERVER_USERNAME

# Env var NAME that holds the OpenCode server HTTP Basic Auth password.
AGENT_OPENCODE_PASSWORD_REF=OPENCODE_SERVER_PASSWORD

# ── OpenCode server credentials (referenced by the _REF vars above) ──────────
# Set these in .env only — never commit real values here.
OPENCODE_SERVER_USERNAME=opencode
# ⚠  Replace with a strong random password before running in any shared environment.
OPENCODE_SERVER_PASSWORD=change-me-to-a-strong-password
